# ----------------------------------------------------------------------------
# Sajad Digital Services — Environment variables
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.
# ----------------------------------------------------------------------------

# MySQL connection string.
# Local (XAMPP):   mysql://root:@localhost:3306/sajid_digital
# Hostinger:       mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME
DATABASE_URL="mysql://root:@localhost:3306/sajid_digital"

# Secret used to sign admin session JWTs. Use a long, random string in production.
AUTH_SECRET="change_me_to_a_long_random_secret"